# PostgreSQL (flower_shop).
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flower_shop
POSTGRES_USER=postgres
# Must match the running database (compose default is postgres).
POSTGRES_PASSWORD=postgres
POSTGRES_SSL_MODE=disable

GRPC_PORT=50052
HTTP_PORT=8082

# Kafka brokers; 127.0.0.1 avoids IPv6 localhost on Windows. Omit to disable the consumer.
BROKERS=127.0.0.1:9092
